{
  "name": "longevity-evidence-layer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "bootstrap:postgres": "node ./scripts/bootstrap-postgres.mjs",
    "verify:meta": "node ./scripts/meta-verify.mjs",
    "seed:postgres:export": "node ./scripts/export-postgres-seed.mjs",
    "seed:postgres:check": "node ./scripts/export-postgres-seed.mjs --check",
    "test:functional": "node ./scripts/functional-tests-file.mjs",
    "test:functional:file": "node ./scripts/functional-tests-file.mjs",
    "test:functional:postgres": "node ./scripts/functional-tests-postgres.mjs",
    "test:functional:parity": "node ./scripts/functional-parity.mjs",
    "test:ui": "node ./scripts/ui-functional-file.mjs",
    "test:ui:file": "node ./scripts/ui-functional-file.mjs",
    "test:ui:postgres": "node ./scripts/ui-functional-postgres.mjs",
    "test:integration": "npm run test:functional:file",
    "test:integration:file": "npm run test:functional:file",
    "test:integration:postgres": "npm run test:functional:postgres",
    "typecheck": "tsc --noEmit --incremental false",
    "docs:verify": "node ./scripts/docs-verify.mjs",
    "verify": "npm run docs:verify && npm run typecheck && npm run build && npm run test:functional:file && npm run test:ui:file"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "next": "latest",
    "pg": "^8.20.0",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/pg": "^8.20.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "playwright": "^1.59.1",
    "typescript": "latest"
  }
}
